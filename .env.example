# ─────────────────────────────────────────────────────────────────────────────
# JM News — environment variables
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored. Never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── WordPress / WPGraphQL ───────────────────────────────────────────────────
# Public GraphQL endpoint. Safe to expose; reads are public.
# (Benchmarked faster than the WP REST API on this host — a single GraphQL
#  query returns posts + author + image + terms in ~0.9s vs ~2.3s for REST
#  `_embed`, and ~2× faster under parallel load — so reads use GraphQL.)
WP_GRAPHQL_URL=https://menorah.com.ng/graphql

# Admin credentials for GraphQL Codegen schema introspection ONLY.
# Generate an Application Password in:
#   wp-admin → Users → Profile → "Application Passwords"
# Use a dedicated WP admin user (or your own) and name the password
# "Codegen". Paste the 24-char password (spaces ok, they're stripped).
WP_ADMIN_USER=
WP_ADMIN_APP_PASSWORD=

# ── Secondary source: WordPress.com REST feed ───────────────────────────────
# A second, independent news source for redundancy. This is a
# wordpress.com-hosted site (no WPGraphQL there), read via the public
# WordPress.com REST API and blended with the primary WPGraphQL feed above —
# if one backend is down, the other keeps the site populated.
# Set to the bare host. Leave blank to disable the second source.
WPCOM_SITE=jabbamanews.wordpress.com

# ── Site ────────────────────────────────────────────────────────────────────
# Public origin — used for canonical URLs, Open Graph images, sitemap & robots.
# No trailing slash. REQUIRED in production (set it on the host too).
NEXT_PUBLIC_SITE_URL=https://jmnews.ng

# ── Matomo analytics (optional) ─────────────────────────────────────────────
# Set BOTH to enable tracking. Get them from your Matomo dashboard after adding
# jmnews.ng as a site. Leave blank to disable (nothing is loaded).
NEXT_PUBLIC_MATOMO_URL=
NEXT_PUBLIC_MATOMO_SITE_ID=

# ── Feature flags ───────────────────────────────────────────────────────────
# When true, the public site reads content from WordPress instead of the
# static fallback in src/lib/*. Flip per data type during Phase 1.
NEXT_PUBLIC_USE_CMS=false

# Read site identity (name/tagline/url) from WP "General Settings".
# Leave false unless your CMS actually serves the `generalSettings` GraphQL
# query — otherwise it errors on every render and the static identity in
# src/lib/site.ts is used anyway.
WP_SITE_SETTINGS=false

# ── Reserved for later phases (leave blank for now) ─────────────────────────
# Phase 1.5: shared secret between WP mu-plugin and /api/revalidate
REVALIDATE_SECRET=

# Phase 6: shared secret for signed draft-preview links
WP_GRAPHQL_PREVIEW_SECRET=
